# ============================================================================
# DHISUM TSEYIG PLATFORM - Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in the values
# 
# NOTE: The POS desktop app automatically connects to:
#       https://jindapos.com
#       No additional configuration needed for the client side.
# ============================================================================

# Development Settings
NEXT_TURBOPACK=0

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# NextAuth
# IMPORTANT: This URL is used for email verification links
# Set this to your stable production URL (not the auto-generated Vercel preview URLs)
NEXTAUTH_SECRET=your-super-secret-key-here-min-32-chars-random
NEXTAUTH_URL=https://jindapos.com

# AWS S3 / Cloudflare R2
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=auto
AWS_BUCKET_NAME=dhisum-tseyig-downloads
AWS_ENDPOINT_URL=https://your-account.r2.cloudflarestorage.com

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# Admin Credentials (for seeding only)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMeImmediately123!
