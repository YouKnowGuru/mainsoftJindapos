{
  "name": "dhisum-tseyig",
  "productName": "Jinda",
  "private": true,
  "version": "1.0.0",
  "description": "Desktop Accounting & POS System for Bhutan",
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "author": "Jinda",
  "scripts": {
    "dev": "concurrently \"vite\" \"node --max-old-space-size=8192 node_modules/typescript/bin/tsc -p tsconfig.electron.json --watch\" \"wait-on http://127.0.0.1:5173 && npx electron .\"",
    "dev:win": "concurrently \"vite\" \"node --max-old-space-size=8192 node_modules/typescript/bin/tsc -p tsconfig.electron.json --watch\" \"wait-on http://127.0.0.1:5173 && npx electron .\"",
    "dev:compile": "node --max-old-space-size=8192 node_modules/typescript/bin/tsc -p tsconfig.electron.json",
    "dev:electron": "wait-on http://127.0.0.1:5173 && npx electron .",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "npm run build && npm run electron:compile && set NODE_ENV=development && npx electron .",
    "electron:start": "npm run build && npm run electron:compile && set NODE_ENV=production && npx electron .",
    "electron:compile": "tsc -p tsconfig.electron.json && node -e \"require('fs').writeFileSync('dist-electron/package.json', JSON.stringify({type:'commonjs'}))\"",
    "dist": "npm run build && npm run electron:compile && electron-builder",
    "dist:win": "npm run build && npm run electron:compile && electron-builder --win",
    "electron:build:win": "npm run dist:win",
    "dist:mac": "npm run build && npm run electron:compile && electron-builder --mac",
    "dist:linux": "npm run build && npm run electron:compile && electron-builder --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "adm-zip": "^0.5.17",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.2.4",
    "electron-updater": "^6.8.9",
    "embla-carousel-react": "^8.6.0",
    "googleapis": "^171.4.0",
    "input-otp": "^1.4.2",
    "ioredis": "^5.10.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "keytar": "^7.9.0",
    "lucide-react": "^0.562.0",
    "megajs": "^1.3.9",
    "next-themes": "^0.4.6",
    "node-cron": "^4.2.1",
    "node-machine-id": "^1.1.12",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.0",
    "react-day-picker": "^9.13.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.70.0",
    "react-resizable-panels": "^4.2.2",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "stream-json": "^1.9.1",
    "tailwind-merge": "^3.4.0",
    "uninstall": "^0.0.0",
    "vaul": "^1.1.2",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/adm-zip": "^0.5.8",
    "@types/archiver": "^7.0.0",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^24.10.1",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "32.3.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "kimi-plugin-inspect-react": "^1.0.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.jinda.app",
    "productName": "Jinda",
    "copyright": "Copyright © 2026 Jinda",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "build/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*",
      "node_modules/dompurify/**/*",
      "node_modules/stream-json/**/*",
      "node_modules/stream-chain/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/better-sqlite3",
        "to": "app/node_modules/better-sqlite3"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Jinda",
      "license": "build/license.txt"
    },
    "publish": {
      "provider": "generic",
      "url": "https://jindapos.com/updates"
    },
    "npmRebuild": false,
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.finance"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "icon": "build",
      "category": "Office",
      "maintainer": "Jinda",
      "vendor": "Jinda",
      "synopsis": "Desktop Accounting & POS System",
      "description": "Complete offline accounting and POS solution for Bhutanese businesses"
    }
  }
}
